<Window
    x:Class="AutoUpdate.GameConfig"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:AutoUpdate"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="GameConfig"
    Width="429"
    Height="239"
    AllowsTransparency="True"
    Background="{x:Null}"
    Loaded="Window_Loaded"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">
    <Window.Resources>
        <Storyboard x:Key="FakeCheckBoxUncheck">
            <BooleanAnimationUsingKeyFrames Storyboard.TargetName="Display_mode_cb" 
                                            Storyboard.TargetProperty="IsChecked">
                <DiscreteBooleanKeyFrame KeyTime="0:0:0" Value="False"/>
                <DiscreteBooleanKeyFrame KeyTime="0:0:0.1" Value="True"/>
            </BooleanAnimationUsingKeyFrames>
        </Storyboard>
    </Window.Resources>
    <Grid Width="429" Height="239" Margin="0,0,0,0">
        <Grid.Background>
            <ImageBrush ImageSource="Resources/config_frame.png" Stretch="Uniform" />
        </Grid.Background>

        <RadioButton
            x:Name="WindowToggle"
            Width="52"
            Height="12"
            Margin="220,93,157,134"
            GroupName="Group1"
            Style="{StaticResource ImgRadioBtn}" />
        <RadioButton
            x:Name="FullScreenToggle"
            Width="52"
            Height="12"
            Margin="47,93,330,134"
            GroupName="Group1"
            Style="{StaticResource ImgRadioBtn}" />

        <CheckBox x:Name="DynamicLight_cb" Style="{StaticResource ImgCheckBox}" 
            HorizontalAlignment="Left" 
            Margin="47,69,0,0"
            VerticalAlignment="Top" 
            Width="52" 
            Height="12"/>
        <CheckBox x:Name="Display_mode_cb" 
                  Style="{StaticResource 3DImgCheckBox}" 
                  HorizontalAlignment="Left" 
                  Margin="220,69,0,0"
                  VerticalAlignment="Top" 
                  Width="52" 
                  Height="12" 
                  IsChecked="True"
                  Unchecked="Display_mode_cb_Unchecked"/>


        <TextBox
            x:Name="txtCapPath"
            Height="17"
            Margin="123,122,92,100"
            VerticalAlignment="Center"
            Background="{x:Null}"
            BorderBrush="{x:Null}"
            BorderThickness="0"
            DataContextChanged="TxtCapPath_DataContextChanged"
            Foreground="White"
            SelectionBrush="#FF29CEFF"
            SelectionOpacity="1"
            Text="ScreenShot"
            TextAlignment="Left" FontWeight="Bold" 
            IsReadOnly="True"/>
        <Button
            x:Name="btnLocate"
            Width="57"
            Height="22"
            Margin="337,122,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Click="BtnLocate_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <StackPanel>
                        <Image
                            Name="btnLocate2"
                            Source="Resources/btn_locate_hover.png"
                            Stretch="UniformToFill"
                            Visibility="Collapsed" />
                        <Image
                            Name="btnLocate1"
                            Source="Resources/btn_locate.png"
                            Stretch="UniformToFill"
                            Visibility="Visible" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="true">
                            <Setter TargetName="btnLocate2" Property="Visibility" Value="Visible" />
                            <Setter TargetName="btnLocate1" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>


        <!--  Confirm button  -->
        <Button
            x:Name="btnConfirm"
            Width="79"
            Height="32"
            Margin="104,185,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Click="BtnConfirm_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <StackPanel>
                        <Image
                            Name="btnConfirm2"
                            Source="Resources/btn_confirm_hover.png"
                            Stretch="UniformToFill"
                            Visibility="Collapsed" />
                        <Image
                            Name="btnConfirm1"
                            Source="Resources/btn_confirm.png"
                            Stretch="UniformToFill"
                            Visibility="Visible" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="true">
                            <Setter TargetName="btnConfirm2" Property="Visibility" Value="Visible" />
                            <Setter TargetName="btnConfirm1" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!--  Default button  -->
        <Button
            x:Name="btnDefault"
            Width="79"
            Height="32"
            Margin="236,185,114,0"
            VerticalAlignment="Top"
            Click="BtnDefault_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <StackPanel>
                        <Image
                            Name="btnDefault2"
                            Source="Resources/btn_huy_hover.png"
                            Stretch="UniformToFill"
                            Visibility="Collapsed" />
                        <Image
                            Name="btnDefault1"
                            Source="Resources/btn_huy.png"
                            Stretch="UniformToFill"
                            Visibility="Visible" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="true">
                            <Setter TargetName="btnDefault2" Property="Visibility" Value="Visible" />
                            <Setter TargetName="btnDefault1" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!--  Close button  -->
        <Button
            x:Name="btnClose"
            Width="19"
            Height="19"
            Margin="408,2,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Click="BtnClose_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <StackPanel>
                        <Image
                            Name="btnClose2"
                            Source="Resources/btn_x_hover.png"
                            Stretch="UniformToFill"
                            Visibility="Collapsed" />
                        <Image
                            Name="btnClose1"
                            Source="Resources/btn_x.png"
                            Stretch="UniformToFill"
                            Visibility="Visible" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="true">
                            <Setter TargetName="btnClose2" Property="Visibility" Value="Visible" />
                            <Setter TargetName="btnClose1" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

    </Grid>
</Window>
