        <Button
            x:Name="btnClose"
            Width="132"
            Height="41"
            Margin="822,449,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            BorderThickness="0"
            Click="BtnClose_Click"
            Cursor="Hand"
            IsHitTestVisible="True"
            ToolTip="Tắt AutoUpdate."
            ToolTipService.ShowDuration="5000">
            <Button.Template>
                <ControlTemplate TargetType="{x:Type Button}">
                    <StackPanel>
                        <Image
                            x:Name="btnClose2"
                            Source="Resources/btn_thoat_hover.png"
                            Stretch="UniformToFill"
                            Visibility="Collapsed" />
                        <Image
                            x:Name="btnClose1"
                            Source="Resources/btn_thoat.png"
                            Stretch="UniformToFill"
                            Visibility="Visible" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="true">
                            <Setter TargetName="btnClose2" Property="Visibility" Value="Visible" />
                            <Setter TargetName="btnClose1" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

