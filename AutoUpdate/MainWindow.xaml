<Window
    x:Class="AutoUpdate.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:gif="http://wpfanimatedgif.codeplex.com"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:AutoUpdate"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="AutoUpdate"
    Width="1200"
    Height="600"
    AllowsTransparency="True"
    Background="{x:Null}"
    FontFamily="./resources/#Segoe UI"
    ForceCursor="True"
    Icon="Resources/kiemthe.ico"
    Loaded="Window_Loaded"
    ResizeMode="CanMinimize"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">
    <Window.Resources>
        <Storyboard x:Key="FadeOut" FillBehavior="Stop">
            <DoubleAnimation
                FillBehavior="Stop"
                Storyboard.TargetName="slideshow"
                Storyboard.TargetProperty="Opacity"
                From="0.05"
                To="1"
                Duration="0:0:1" />
        </Storyboard>
        <Storyboard x:Key="FadeIn" FillBehavior="Stop">
            <DoubleAnimation
                FillBehavior="Stop"
                Storyboard.TargetName="slideshow"
                Storyboard.TargetProperty="Opacity"
                From="1"
                To=".05"
                Duration="0:0:1" />
        </Storyboard>
    </Window.Resources>

    <Grid x:Name="MainGrid" Width="Auto">
        <Grid.Background>
            <ImageBrush ImageSource="Resources/background.png" Stretch="UniformToFill" />
        </Grid.Background>
